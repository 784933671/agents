{
  "mcpServers": {
    "学工系统": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "apifox-mcp-server@latest",
        "--project-id=${user_config.apifox_project_id}"
      ],
      "env": {
        "APIFOX_ACCESS_TOKEN": "${user_config.apifox_access_token}"
      }
    }
  }
}
